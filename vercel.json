{
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/apify/sync",
      "schedule": "0 6 */3 * *"
    },
    {
      "path": "/api/apify/collect",
      "schedule": "25 6 */3 * *"
    },
    {
      "path": "/api/cron/watchdog",
      "schedule": "0 7 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "thesteadyone.com"
        }
      ],
      "destination": "https://www.thesteadyone.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "withpepe.com"
        }
      ],
      "destination": "https://www.thesteadyone.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.withpepe.com"
        }
      ],
      "destination": "https://www.thesteadyone.com/:path*",
      "permanent": true
    }
  ]
}
